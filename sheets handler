import axios from "axios";
import { retry } from "../utils/retry.js";
import { logIntegration } from "../utils/logger.js";

export async function sendToSheets(integration, eventType, payload) {
  return retry(async () => {
    await axios.post(integration.endpoint, {
      event: eventType,
      row: payload
    });

    logIntegration({
      type: "sheets",
      status: "success",
      eventType
    });
  });
}