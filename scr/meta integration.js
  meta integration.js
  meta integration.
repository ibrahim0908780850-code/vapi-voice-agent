import express from "express";
import { routeIntegration } from "../integration.dispatcher.js";

const router = express.Router();

/**
 * 🔍 Detect Channel
 */
function detectChannel(entry) {
  if (entry.messaging?.[0]?.message?.is_echo) return "ignore";

  if (entry.id?.includes("instagram")) return "instagram";

  if (entry.id?.includes("page")) return "messenger";

  return "whatsapp";
}

/**
 * 📥 Meta Webhook Entry
 */
router.post("/meta/webhook", async (req, res) => {
  try {

    const body = req.body;

    const entry = body.entry?.[0];
    const messaging = entry?.messaging?.[0];

    const channel = detectChannel(entry);

    const event = {
      tenant_id: extractTenant(entry),
      channel,
      user_id: messaging.sender.id,
      message: messaging.message?.text,
      raw: body
    };

    await routeIntegration(event);

    res.sendStatus(200);

  } catch (err) {
    console.error(err.message);
    res.sendStatus(500);
  }
});

export default router;