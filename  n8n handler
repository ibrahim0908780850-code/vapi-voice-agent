import axios from "axios";
import { retry } from "../utils/retry.js";
import { logIntegration } from "../utils/logger.js";

export async function sendToN8N(integration, eventType, payload) {
  return retry(async () => {
    await axios.post(integration.endpoint, {
      event: eventType,
      data: payload
    });

    logIntegration({
      type: "n8n",
      status: "success",
      eventType
    });
  });
}